    "#import logging\n",
    "import time\n",
    "import threading\n",
    "\n",
    "def thread_func(name):\n",
    "    print(f\"Thread starting:: {name}\")\n",
    "    time.sleep(2)\n",
    "    print(f\"Thread finishing:: {name}\")\n",
    "\n",
    "x=threading.Thread(target=thread_func, args=(1,))\n",
    "x.start()\n",
    "print(\"ALL DONE\")"
   ]
